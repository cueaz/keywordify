{
  "name": "@keywordify/html",
  "version": "1.1.5",
  "description": "A keywordified fork of lit-html and @lit-labs/preact-signals with custom modifications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cueaz/keywordify.git",
    "directory": "keywordify/html"
  },
  "license": "BSD-3-Clause",
  "author": "cueaz",
  "type": "module",
  "sideEffects": false,
  "keywordified": true,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/__dev__/index.d.ts",
      "development": "./dist/__dev__/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "clean-pkg-json --keep keywordified",
    "build": "rolldown --config",
    "test": "vitest run",
    "typegen": "keywords"
  },
  "peerDependencies": {
    "@keywordify/signals": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@keywordify/signals": {
      "optional": true
    }
  },
  "devDependencies": {
    "@keywordify/signals": "workspace:*",
    "@types/trusted-types": "catalog:"
  }
}
